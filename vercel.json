
{
  "version": 2,
  "builds": [
    {
      "src": "api/board.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "functions": {
    "api/board.js": {
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/api/board",
      "dest": "/api/board.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
